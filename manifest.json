{
  "manifest_version": 3,
  "name": "Vocab Builder - Pro",
  "version": "1.0",
  "description": "අලුත් ඉංග්‍රීසි වචන ඉගෙන ගන්න උදව් වෙන Extension එකක්.",
  "permissions": ["contextMenus", "storage", "notifications"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}